# Copy to .env and fill in as needed. All values are optional; the system runs
# end-to-end offline with the NumPy index and a deterministic hashing embedder.

# --- Paths (all relative to the project root unless absolute) ---
# F1RAG_PROJECT_ROOT=.
# F1RAG_DATA_DIR=data
# F1RAG_INDEX_DIR=indexes
# F1RAG_EXPERIMENT_DIR=experiments

# --- Default component selection (overridable via CLI flags) ---
# F1RAG_CHUNKER=regulation           # regulation | fixed_window
# F1RAG_EMBEDDER=minilm              # minilm | hashing
# F1RAG_INDEX=numpy                  # numpy | chroma
# F1RAG_RETRIEVER=vector            # vector | bm25 | hybrid
# F1RAG_RERANKER=none               # none
# F1RAG_GENERATOR=anthropic         # anthropic

# --- Embeddings ---
# F1RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# F1RAG_EMBEDDING_BATCH_SIZE=32

# --- Chunking ---
# F1RAG_CHUNK_MAX_TOKENS=350
# F1RAG_CHUNK_OVERLAP_TOKENS=60

# --- Generation (Anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-...
# F1RAG_GENERATION_MODEL=claude-3-5-sonnet-20241022
# F1RAG_GENERATION_MAX_TOKENS=1024
# Temperature is intentionally fixed to 0 in code for reproducibility.
